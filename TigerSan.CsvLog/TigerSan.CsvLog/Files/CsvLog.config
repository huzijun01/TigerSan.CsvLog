<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <logSettings>
    <!-- 保存Log的文件夹。
    若为空，则保存在程序运行路径下的Log文件夹中。
    支持相对路径，相对于程序的运行路径。-->
    <add key="LogDir" value=""/>
    <!-- Log的文件名前缀。
    若为空，则使用"log_"。
    前缀后会自动补上时间戳。-->
    <add key="FileName" value=""/>
  </logSettings>
</configuration>